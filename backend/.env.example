NODE_ENV=production
PORT=4000
MONGO_URI=mongodb://127.0.0.1:27017/leadgen_saas
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d
TENANT_HEADER=X-Company-Id
CORS_ORIGINS=https://leadgen.narrowpathevents.com,http://localhost:5173

# Required for super user login (/auth/super/login)
SUPER_ADMIN_EMAIL=owner@narrowpathevents.com
SUPER_ADMIN_PASSWORD=change_this_super_strong_password
SUPER_ADMIN_NAME=Platform Owner

# Optional initial company bootstrap (creates tenant + company_admin user)
BOOTSTRAP_COMPANY_ENABLED=true
BOOTSTRAP_COMPANY_NAME=Narrow Path Events
BOOTSTRAP_COMPANY_SLUG=narrow-path-events
BOOTSTRAP_ADMIN_EMAIL=admin@narrowpathevents.com
BOOTSTRAP_ADMIN_PASSWORD=change_this_company_admin_password
BOOTSTRAP_ADMIN_NAME=NPE Company Admin
